# SmartStudy AI — Environment Variables
# Copy to .env and fill in your keys

# Claude API (for Module D: CodeLens suite)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Ollama (local, auto-detected)
OLLAMA_HOST=http://localhost:11434

# LightRAG (local, auto-detected)
LIGHTRAG_HOST=http://localhost:9621

# Optional tool-specific model routing after fine-tuning/export
# Examples:
# SMARTSTUDY_MODEL_GENERAL=gemma4:e2b
# SMARTSTUDY_MODEL_QUIZVERSE=smartstudy-edu
# SMARTSTUDY_MODEL_DSASAGE=smartstudy-dsa
# SMARTSTUDY_MODEL_STUDIO=smartstudy-studio
# SMARTSTUDY_MODEL_DOCREAD=gemma3:latest

SMARTSTUDY_MODEL_GENERAL=
SMARTSTUDY_MODEL_QUIZVERSE=
SMARTSTUDY_MODEL_PREPMASTER=
SMARTSTUDY_MODEL_DSASAGE=
SMARTSTUDY_MODEL_STUDIO=
SMARTSTUDY_MODEL_DOCREAD=
SMARTSTUDY_MODEL_PAPERANALYZER=
SMARTSTUDY_MODEL_CODELENS=
